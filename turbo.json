{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "tsconfig*.json",
        "../../tsconfig.base.json"
      ],
      "outputs": ["dist/**", "build/**", ".react-router/**"]
    },
    "lint": {
      "inputs": ["$TURBO_DEFAULT$", "../../biome.json"]
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "tsconfig*.json",
        "../../tsconfig.base.json"
      ]
    },
    "test": {
      "dependsOn": ["build"],
      "inputs": ["$TURBO_DEFAULT$", "../../vitest.workspace.ts", "fixtures/**"]
    },
    "clean": {
      "cache": false
    }
  }
}
